<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>C&I 360 – Opportunity Redesign</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style>
/* ── Reset & tokens ─────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
–sf-blue:       #0176d3;
–sf-blue-dark:  #014486;
–sf-blue-light: #e8f4fd;
–sf-cloud:      #f3f3f3;
–sf-border:     #dddbda;
–sf-text:       #181818;
–sf-muted:      #706e6b;
–sf-success:    #2e844a;
–sf-warning:    #fe9339;
–sf-danger:     #c23934;
–sf-purple:     #6929c4;
–sf-teal:       #0e7490;

/* New accent – a warm slate that’s distinctly not stock SF */
–accent:        #1B4F72;
–accent-light:  #d6eaf8;
–sla-green:     #d5f5e3;
–sla-red:       #fde8e8;
–cap-green:     #27ae60;

–font: ‘IBM Plex Sans’, sans-serif;
–mono: ‘IBM Plex Mono’, monospace;
–radius: 6px;
–shadow-sm: 0 1px 4px rgba(0,0,0,.10);
–shadow-md: 0 4px 16px rgba(0,0,0,.12);
}

body {
font-family: var(–font);
font-size: 13px;
background: #f0f0ef;
color: var(–sf-text);
min-width: 1200px;
}

/* ── Global Nav ─────────────────────────────────────────────────────── */
.global-nav {
background: #032d60;
height: 48px;
display: flex;
align-items: center;
padding: 0 16px;
gap: 16px;
position: sticky;
top: 0;
z-index: 100;
box-shadow: 0 2px 8px rgba(0,0,0,.25);
}
.global-nav .logo {
width: 32px; height: 32px;
background: #fff;
border-radius: 50%;
display: flex; align-items: center; justify-content: center;
flex-shrink: 0;
}
.global-nav .logo svg { width: 20px; height: 20px; }
.global-nav .app-name {
color: #fff;
font-weight: 700;
font-size: 14px;
letter-spacing: .3px;
white-space: nowrap;
}
.global-nav .search-bar {
flex: 1; max-width: 480px; margin: 0 auto;
background: rgba(255,255,255,.15);
border: 1px solid rgba(255,255,255,.25);
border-radius: 20px;
display: flex; align-items: center;
padding: 0 12px; gap: 8px;
color: rgba(255,255,255,.8);
font-size: 13px;
height: 32px;
}
.global-nav .search-bar input {
background: none; border: none; outline: none;
color: #fff; font-family: var(–font); font-size: 13px; flex: 1;
}
.global-nav .search-bar input::placeholder { color: rgba(255,255,255,.6); }
.nav-icons { display: flex; gap: 4px; margin-left: auto; }
.nav-icons button {
background: none; border: none; cursor: pointer;
color: rgba(255,255,255,.85); width: 32px; height: 32px;
border-radius: 50%; display: flex; align-items: center; justify-content: center;
font-size: 16px; transition: background .15s;
}
.nav-icons button:hover { background: rgba(255,255,255,.15); }
.avatar {
width: 30px; height: 30px; border-radius: 50%;
background: linear-gradient(135deg, #27ae60, #2e86c1);
display: flex; align-items: center; justify-content: center;
color: #fff; font-weight: 700; font-size: 12px; cursor: pointer;
}

/* ── App Nav Bar ─────────────────────────────────────────────────────── */
.app-nav {
background: #fff;
border-bottom: 1px solid var(–sf-border);
display: flex; align-items: center;
padding: 0 16px;
height: 40px;
gap: 2px;
overflow-x: auto;
}
.app-nav-item {
padding: 0 12px; height: 40px;
display: flex; align-items: center;
font-size: 13px; font-weight: 500;
color: var(–sf-muted);
border-bottom: 2px solid transparent;
cursor: pointer; white-space: nowrap;
transition: color .15s, border-color .15s;
gap: 4px;
}
.app-nav-item:hover { color: var(–sf-blue); }
.app-nav-item.active { color: var(–sf-blue); border-bottom-color: var(–sf-blue); }
.app-nav-item .chevron { font-size: 10px; opacity: .6; }

/* ── Breadcrumb ──────────────────────────────────────────────────────── */
.breadcrumb {
padding: 8px 16px;
font-size: 12px;
color: var(–sf-muted);
display: flex; align-items: center; gap: 6px;
}
.breadcrumb a { color: var(–sf-blue); text-decoration: none; }
.breadcrumb a:hover { text-decoration: underline; }

/* ── Three-column shell ──────────────────────────────────────────────── */
.page-shell {
display: grid;
grid-template-columns: 260px 1fr 300px;
gap: 0;
min-height: calc(100vh - 88px);
}

/* ── LEFT RAIL ───────────────────────────────────────────────────────── */
.left-rail {
background: #fff;
border-right: 1px solid var(–sf-border);
padding: 12px 0;
overflow-y: auto;
}
.rail-section-hdr {
padding: 8px 16px 4px;
font-size: 11px; font-weight: 700;
text-transform: uppercase; letter-spacing: .8px;
color: var(–sf-muted);
display: flex; align-items: center; justify-content: space-between;
cursor: pointer;
}
.rail-section-hdr .toggle { font-size: 10px; transition: transform .2s; }
.activity-filters {
padding: 8px 16px;
display: flex; gap: 6px; flex-wrap: wrap;
}
.filter-pill {
background: var(–sf-cloud);
border: 1px solid var(–sf-border);
border-radius: 12px;
padding: 2px 10px;
font-size: 11px;
cursor: pointer;
transition: all .15s;
}
.filter-pill:hover, .filter-pill.active {
background: var(–accent-light);
border-color: var(–sf-blue);
color: var(–sf-blue);
}
.activity-empty {
padding: 16px;
text-align: center;
color: var(–sf-muted);
font-size: 12px;
line-height: 1.5;
}
.btn-show-all {
display: block; margin: 8px 16px;
background: var(–sf-blue);
color: #fff; border: none; border-radius: var(–radius);
padding: 6px 12px; font-size: 12px; font-weight: 600;
cursor: pointer; text-align: center;
transition: background .15s;
}
.btn-show-all:hover { background: var(–sf-blue-dark); }

/* Recent items */
.recent-item {
display: flex; align-items: flex-start; gap: 10px;
padding: 10px 16px;
border-top: 1px solid var(–sf-border);
}
.recent-icon {
width: 28px; height: 28px; border-radius: 4px;
background: #ff5722;
display: flex; align-items: center; justify-content: center;
flex-shrink: 0; font-size: 14px;
}
.recent-item-body { font-size: 12px; line-height: 1.6; }
.recent-item-body a { color: var(–sf-blue); text-decoration: none; font-weight: 600; }
.recent-item-body .meta { color: var(–sf-muted); font-size: 11px; }

/* SLA summary in left rail — NEW UX ADDITION */
.sla-card {
margin: 12px 16px;
border-radius: var(–radius);
border: 1px solid;
padding: 10px 12px;
font-size: 12px;
}
.sla-card.active {
background: var(–sla-green);
border-color: #27ae60;
}
.sla-card.hold {
background: var(–sla-red);
border-color: var(–sf-danger);
}
.sla-card .sla-label {
font-weight: 700; font-size: 11px; text-transform: uppercase;
letter-spacing: .5px; margin-bottom: 4px;
}
.sla-card.active .sla-label { color: #1a6b35; }
.sla-card.hold   .sla-label { color: var(–sf-danger); }
.sla-timer { font-family: var(–mono); font-size: 20px; font-weight: 600; }
.sla-card.active .sla-timer { color: #145a32; }
.sla-card.hold   .sla-timer { color: var(–sf-danger); }

/* ── MAIN CONTENT ────────────────────────────────────────────────────── */
.main-content {
overflow-y: auto;
display: flex;
flex-direction: column;
}

/* Record header */
.record-header {
background: #fff;
border-bottom: 1px solid var(–sf-border);
padding: 14px 20px 0;
}
.record-meta {
display: flex; align-items: flex-start; justify-content: space-between;
gap: 16px; margin-bottom: 12px;
}
.record-type-badge {
font-size: 11px; font-weight: 600; text-transform: uppercase;
letter-spacing: .6px; color: var(–sf-muted); margin-bottom: 2px;
display: flex; align-items: center; gap: 6px;
}
.record-icon-inline {
width: 20px; height: 20px; border-radius: 3px;
background: #ff5722; display: inline-flex;
align-items: center; justify-content: center; font-size: 11px;
}
.record-id {
font-size: 22px; font-weight: 700; color: var(–sf-blue);
letter-spacing: -.3px; cursor: pointer;
display: flex; align-items: center; gap: 8px;
}
.record-id:hover { text-decoration: underline; }

/* Validation badges — NEW */
.validation-badges {
display: flex; gap: 6px; align-items: center; flex-wrap: wrap;
margin-top: 4px;
}
.badge {
display: inline-flex; align-items: center; gap: 4px;
padding: 3px 8px; border-radius: 10px;
font-size: 11px; font-weight: 600; letter-spacing: .2px;
}
.badge-validated { background: #d5f5e3; color: #145a32; }
.badge-unvalidated { background: #fde8e8; color: #c23934; }
.badge-legal-hold  { background: #fef3c7; color: #92400e; }
.badge-mmkt        { background: #ede9fe; color: #5b21b6; }
.badge-forecasted  { background: #dbeafe; color: #1e40af; }
.badge-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

/* Action buttons row */
.action-row {
display: flex; align-items: center; gap: 8px;
}
.btn {
display: inline-flex; align-items: center; gap: 5px;
padding: 0 14px; height: 32px;
border-radius: var(–radius);
font-size: 13px; font-weight: 600; font-family: var(–font);
cursor: pointer; border: 1px solid; transition: all .15s;
white-space: nowrap;
}
.btn-primary {
background: var(–sf-blue); color: #fff; border-color: var(–sf-blue);
}
.btn-primary:hover { background: var(–sf-blue-dark); border-color: var(–sf-blue-dark); }
.btn-outline {
background: #fff; color: var(–sf-text); border-color: var(–sf-border);
}
.btn-outline:hover { background: var(–sf-cloud); }
.btn-success {
background: var(–sf-success); color: #fff; border-color: var(–sf-success);
}
.btn-danger-outline {
background: #fff; color: var(–sf-danger); border-color: var(–sf-danger);
}
.btn-caret {
padding: 0 8px; border-left: none; border-radius: 0 var(–radius) var(–radius) 0;
}
.btn-group { display: flex; }
.btn-group .btn:first-child { border-radius: var(–radius) 0 0 var(–radius); }
.btn-group .btn-caret { border-left: 1px solid rgba(255,255,255,.4); }

/* KPI strip */
.kpi-strip {
display: grid;
grid-template-columns: repeat(6, 1fr);
gap: 0;
border-top: 1px solid var(–sf-border);
margin-top: 12px;
}
.kpi-cell {
padding: 10px 14px;
border-right: 1px solid var(–sf-border);
cursor: pointer;
transition: background .15s;
}
.kpi-cell:last-child { border-right: none; }
.kpi-cell:hover { background: var(–sf-cloud); }
.kpi-label {
font-size: 11px; color: var(–sf-muted); margin-bottom: 3px;
display: flex; align-items: center; gap: 4px;
}
.kpi-label .info-icon { font-size: 10px; opacity: .7; cursor: help; }
.kpi-value {
font-size: 15px; font-weight: 700; color: var(–sf-text);
}
.kpi-value.blue  { color: var(–sf-blue); }
.kpi-value.green { color: var(–sf-success); }
.kpi-value.warn  { color: var(–sf-warning); }
.kpi-sub { font-size: 10px; color: var(–sf-muted); margin-top: 1px; }

/* Chevron stage bar */
.stage-bar {
background: #fff;
border-bottom: 2px solid var(–sf-border);
padding: 0 20px;
}
.chevrons {
display: flex; align-items: stretch;
height: 42px; gap: 0; position: relative;
}
.chevron {
display: flex; align-items: center; justify-content: center;
padding: 0 20px 0 28px;
font-size: 12px; font-weight: 600;
position: relative; cursor: pointer;
clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 50%, calc(100% - 14px) 100%, 0 100%, 14px 50%);
transition: filter .15s;
white-space: nowrap;
min-width: 100px; flex: 1;
}
.chevron:first-child {
clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 50%, calc(100% - 14px) 100%, 0 100%);
padding-left: 16px;
}
.chevron:last-child {
clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%, 14px 50%);
}
.chevron:hover { filter: brightness(.92); }
.chev-done     { background: #d5f5e3; color: #145a32; }
.chev-active   { background: var(–sf-blue); color: #fff; }
.chev-new      { background: #e0f2fe; color: #0369a1; } /* new “Scoping” stage */
.chev-future   { background: var(–sf-cloud); color: var(–sf-muted); }
.chev-closed   { background: #f1f5f9; color: var(–sf-muted); }
.chev-new-badge {
position: absolute; top: 4px; right: 20px;
background: var(–cap-green); color: #fff;
font-size: 8px; font-weight: 800; padding: 1px 4px; border-radius: 3px;
letter-spacing: .3px;
}

.stage-meta {
padding: 8px 0 10px;
display: flex; align-items: center; justify-content: space-between;
flex-wrap: wrap; gap: 8px;
}
.stage-label { font-size: 12px; font-weight: 600; color: var(–sf-muted); }
.stage-label span { color: var(–sf-blue); }

/* Guidance box */
.guidance-box {
margin: 0 20px 16px;
background: #f8fbff;
border: 1px solid #b3d4f5;
border-left: 4px solid var(–sf-blue);
border-radius: var(–radius);
padding: 14px 16px;
font-size: 12.5px;
}
.guidance-box h4 {
font-size: 12px; font-weight: 700; margin-bottom: 8px;
color: var(–accent); letter-spacing: .2px;
display: flex; align-items: center; gap: 6px;
}
.guidance-box ol { padding-left: 20px; }
.guidance-box li { margin-bottom: 6px; line-height: 1.5; color: var(–sf-text); }

/* ── NOTICE BANNER (SLA / validation) ───────────────────────────────── */
.notice-banner {
margin: 0 20px 12px;
border-radius: var(–radius);
padding: 10px 14px;
display: flex; align-items: flex-start; gap: 10px;
font-size: 12.5px;
}
.notice-banner.info  { background: var(–accent-light); border: 1px solid #85c1e9; color: #154360; }
.notice-banner.warn  { background: #fef3c7; border: 1px solid #fcd34d; color: #78350f; }
.notice-banner.error { background: #fde8e8; border: 1px solid #f5c6cb; color: #7b1a1a; }
.notice-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }
.notice-text strong { font-weight: 700; display: block; margin-bottom: 2px; }

/* ── TABS ─────────────────────────────────────────────────────────────── */
.detail-tabs {
background: #fff;
border-bottom: 1px solid var(–sf-border);
display: flex; align-items: center; gap: 0;
padding: 0 20px;
}
.tab {
padding: 0 16px; height: 40px;
display: flex; align-items: center;
font-size: 13px; font-weight: 500; color: var(–sf-muted);
border-bottom: 3px solid transparent;
cursor: pointer; transition: all .15s;
white-space: nowrap; gap: 5px;
}
.tab:hover { color: var(–sf-blue); }
.tab.active { color: var(–sf-blue); border-bottom-color: var(–sf-blue); }
.tab-count {
background: var(–sf-cloud); border-radius: 10px;
padding: 1px 6px; font-size: 11px;
}
.tab.active .tab-count { background: var(–accent-light); color: var(–sf-blue); }
.tab-new-badge {
background: var(–cap-green); color: #fff;
font-size: 9px; font-weight: 800; padding: 1px 5px; border-radius: 3px;
}

/* ── DETAIL SECTIONS ─────────────────────────────────────────────────── */
.detail-body {
padding: 16px 20px;
display: flex; flex-direction: column; gap: 14px;
}

.section-card {
background: #fff;
border: 1px solid var(–sf-border);
border-radius: var(–radius);
box-shadow: var(–shadow-sm);
overflow: hidden;
}
.section-hdr {
padding: 10px 16px;
display: flex; align-items: center; justify-content: space-between;
border-bottom: 1px solid var(–sf-border);
cursor: pointer;
background: var(–sf-cloud);
}
.section-hdr h3 {
font-size: 13px; font-weight: 700; color: var(–sf-text);
display: flex; align-items: center; gap: 7px;
}
.section-hdr .section-icon { font-size: 14px; }
.section-toggle { color: var(–sf-muted); font-size: 11px; transition: transform .2s; }
.section-body { padding: 14px 16px; }

.field-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 0;
}
.field-grid.three-col { grid-template-columns: 1fr 1fr 1fr; }

.field-row {
padding: 8px 10px;
border-bottom: 1px solid #f0f0ef;
border-right: 1px solid #f0f0ef;
display: flex; flex-direction: column; gap: 2px;
transition: background .12s;
cursor: pointer;
position: relative;
}
.field-row:hover { background: var(–sf-cloud); }
.field-row:hover .field-edit-icon { opacity: 1; }
.field-label {
font-size: 11px; color: var(–sf-muted); font-weight: 500;
display: flex; align-items: center; gap: 4px;
}
.field-label .fi { font-size: 10px; opacity: .7; cursor: help; }
.field-value {
font-size: 13px; color: var(–sf-text); font-weight: 500;
min-height: 18px;
}
.field-value.link { color: var(–sf-blue); cursor: pointer; }
.field-value.link:hover { text-decoration: underline; }
.field-value.empty { color: var(–sf-muted); font-style: italic; font-weight: 400; }
.field-value.highlight { color: var(–sf-success); font-weight: 700; }
.field-edit-icon {
position: absolute; top: 8px; right: 8px;
opacity: 0; transition: opacity .15s;
font-size: 12px; color: var(–sf-blue);
}
.field-new-tag {
font-size: 9px; background: var(–cap-green); color: #fff;
padding: 1px 4px; border-radius: 3px; font-weight: 700;
margin-left: 4px; vertical-align: middle;
}
.field-full { grid-column: 1 / -1; }

/* Probability visual — NEW UX */
.prob-visual {
margin-top: 6px;
height: 6px; border-radius: 3px;
background: #e2e8f0; overflow: hidden;
}
.prob-bar { height: 100%; border-radius: 3px; transition: width .4s ease; }

/* AGM Incentive tracker mini-widget — NEW */
.agm-widget {
padding: 12px 16px;
background: linear-gradient(135deg, #eaf6ff 0%, #f0fdf4 100%);
border-top: 1px solid var(–sf-border);
}
.agm-widget-hdr {
font-size: 11px; font-weight: 700; text-transform: uppercase;
letter-spacing: .6px; color: var(–sf-muted); margin-bottom: 10px;
display: flex; justify-content: space-between; align-items: center;
}
.agm-target-row {
display: flex; gap: 12px; flex-wrap: wrap;
}
.agm-target-cell {
flex: 1; min-width: 100px;
background: #fff;
border: 1px solid var(–sf-border);
border-radius: var(–radius);
padding: 8px 10px;
}
.agm-target-cell .atc-label { font-size: 10px; color: var(–sf-muted); margin-bottom: 2px; }
.agm-target-cell .atc-val   { font-size: 15px; font-weight: 700; color: var(–accent); font-family: var(–mono); }
.agm-progress {
margin-top: 10px;
}
.agm-progress-label {
font-size: 11px; color: var(–sf-muted);
display: flex; justify-content: space-between; margin-bottom: 4px;
}
.agm-bar-track {
height: 10px; background: #e2e8f0; border-radius: 5px; overflow: hidden;
}
.agm-bar-fill {
height: 100%;
background: linear-gradient(90deg, #27ae60, #2ecc71);
border-radius: 5px;
width: 68%;
}

/* NAICS drill-down visual — NEW */
.naics-drilldown {
display: flex; gap: 6px; align-items: center; flex-wrap: wrap;
padding: 8px 10px;
background: #f8fbff;
border: 1px dashed #b3d4f5;
border-radius: var(–radius);
margin-top: 4px;
}
.naics-level {
display: flex; flex-direction: column;
align-items: center;
}
.naics-level-label { font-size: 9px; color: var(–sf-muted); text-transform: uppercase; letter-spacing: .4px; }
.naics-level-val {
background: var(–sf-blue); color: #fff;
font-family: var(–mono); font-size: 11px; font-weight: 600;
padding: 3px 8px; border-radius: 4px; margin-top: 2px;
}
.naics-arrow { color: var(–sf-muted); font-size: 12px; margin-top: 10px; }
.naics-autofilled {
font-size: 10px; color: #1a6b35; background: #d5f5e3;
padding: 2px 7px; border-radius: 10px; font-weight: 600;
margin-top: 8px;
}

/* ── RIGHT RAIL ──────────────────────────────────────────────────────── */
.right-rail {
background: #fff;
border-left: 1px solid var(–sf-border);
overflow-y: auto;
}
.rail-card {
border-bottom: 1px solid var(–sf-border);
}
.rail-card-hdr {
padding: 10px 14px;
display: flex; align-items: center; justify-content: space-between;
cursor: pointer;
transition: background .15s;
}
.rail-card-hdr:hover { background: var(–sf-cloud); }
.rail-card-hdr h4 {
font-size: 12px; font-weight: 700; color: var(–sf-text);
display: flex; align-items: center; gap: 6px;
}
.rail-card-body { padding: 0 14px 12px; }

.quick-link {
display: flex; align-items: center; gap: 8px;
padding: 7px 0;
border-bottom: 1px solid var(–sf-border);
cursor: pointer; text-decoration: none;
color: var(–sf-blue); font-size: 12px;
transition: color .12s;
}
.quick-link:last-child { border-bottom: none; }
.quick-link:hover { color: var(–sf-blue-dark); }
.quick-link .ql-icon {
width: 20px; height: 20px; border-radius: 3px;
display: flex; align-items: center; justify-content: center;
font-size: 12px; flex-shrink: 0;
}
.quick-link .ql-count {
margin-left: auto;
background: var(–sf-cloud); border-radius: 10px;
padding: 1px 6px; font-size: 10px; color: var(–sf-muted);
}

/* Ramp years list */
