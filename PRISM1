<script>
// Minimal interactivity for demo feel
document.querySelectorAll('.section-hdr').forEach(hdr => {
  hdr.addEventListener('click', () => {
    const body = hdr.nextElementSibling;
    const toggle = hdr.querySelector('.section-toggle');
    if (body) {
      const collapsed = body.style.display === 'none';
      body.style.display = collapsed ? '' : 'none';
      if (toggle) toggle.style.transform = collapsed ? '' : 'rotate(-90deg)';
    }
  });
});
document.querySelectorAll('.rail-card-hdr').forEach(hdr => {
  hdr.addEventListener('click', () => {
    const body = hdr.nextElementSibling;
    if (body && body.classList.contains('rail-card-body')) {
      body.style.display = body.style.display === 'none' ? '' : 'none';
    }
    const sla = hdr.nextElementSibling;
    if (sla && sla.classList.contains('sla-widget')) {
      sla.style.display = sla.style.display === 'none' ? '' : 'none';
    }
  });
});
document.querySelectorAll('.chevron').forEach(ch => {
  ch.addEventListener('click', () => {
    document.querySelectorAll('.chevron').forEach(c => {
      c.classList.remove('chev-active');
      if (!c.classList.contains('chev-done') && !c.classList.contains('chev-new') && !c.classList.contains('chev-closed'))
        c.classList.add('chev-future');
    });
    ch.classList.remove('chev-future', 'chev-new');
    ch.classList.add('chev-active');
  });
});
// Animate SLA timer
let totalSeconds = 4 * 86400 + 7 * 3600 + 22 * 60 + 14;
function pad(n) { return String(n).padStart(2, '0'); }
setInterval(() => {
  totalSeconds++;
  const d = Math.floor(totalSeconds / 86400);
  const h = Math.floor((totalSeconds % 86400) / 3600);
  const m = Math.floor((totalSeconds % 3600) / 60);
  const s = totalSeconds % 60;
  const str = `${d}d ${pad(h)}:${pad(m)}:${pad(s)}`;
  document.querySelectorAll('.sla-timer, .sla-timer-large').forEach(el => el.textContent = str.replace(':'+pad(s),''));
}, 1000);
</script>

